{
  "name": "esolang-battle-2-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w apps/backend",
    "dev:web": "npm run dev -w apps/web",
    "dev:worker": "npm run dev -w apps/worker",
    "dev:frontend": "npm run dev -w apps/frontend",
    "build": "npm run build --workspaces",
    "generate": "npm run generate -w apps/backend"
  },
  "type": "module",
  "devDependencies": {
    "typescript": "^6.0.2",
    "prisma": "^7.7.0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@prisma/client": "^7.7.0",
    "@prisma/adapter-pg": "^7.7.0",
    "pg": "^8.20.0"
  }
}
